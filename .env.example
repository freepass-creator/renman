# jpkerp6(renman) 환경변수 예시 — 실값은 .env.local(gitignore)에. 자세한 순서는 DEPLOY.md.
# NEXT_PUBLIC_* = 브라우저 노출(클라), 그 외 = 서버 전용.

# ── Firebase (프로덕션 필수 · 없으면 앱이 'no-backend' 하드 차단) ──
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── API 라우트 잠금 (OCR·문자·연동 무단호출 차단) ──
# 서버·클라 같은 값. prod에서 미설정 시 /api/* 503(안전). 로컬만 없이 통과.
API_SHARED_SECRET=
NEXT_PUBLIC_API_SHARED_SECRET=

# ── 본사 마스터 계정(옵션 · 기본 pyh@teamjpk.com은 코드 상수) ──
NEXT_PUBLIC_MASTER_EMAIL=

# ── OCR (자동차등록증·증권 등) ──
GEMINI_API_KEY=

# ── SMS (ALIGO) — 실키 붙이기 전엔 mock 유지(악용 0). DRY_RUN=1이면 미발송 ──
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER_KEY=
ALIGO_SENDER_TEL=
ALIGO_DRY_RUN=1
ALIGO_FAILOVER=

# ── 파일 저장: 회사 Google Workspace Drive (jpkerp5 값 재사용) ──
# 데이터=Firebase · 파일(등록증·보험·할부·계약서 스캔)=회사 Drive. NEXT_PUBLIC_DRIVE_MIRROR=1이면 활성.
GOOGLE_SERVICE_ACCOUNT_KEY=
GOOGLE_IMPERSONATE_USER=pyh@teamjpk.com
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SHARED_DRIVE_ID=
NEXT_PUBLIC_DRIVE_MIRROR=

# ── 프리패스(freepasserp4) 상품 연동 — 미설정 시 자동연동 OFF(안전) ──
# NEXT_PUBLIC_FREEPASS_SYNC=1이면 차량 상태 상품대기 시 자동 push.
# FREEPASS_PRODUCT_API=erp4 수신 엔드포인트 URL(아직 미구현 시 비워두면 '연동 대기').
NEXT_PUBLIC_FREEPASS_SYNC=
FREEPASS_PRODUCT_API=
FREEPASS_API_SECRET=
NEXT_PUBLIC_FREEPASS_PROVIDER_CODE=renman

# ── 마이그레이션(스위치플랜 실데이터 로드) ──
# auto(기본): live xlsx → frozen JSON → demo. live만 강제하려면 live.
NEXT_PUBLIC_MIGRATE_MODE=
JPK_MIGRATE_MODE=
MIGRATE_ROOT=
MIGRATE_BIZ_PATH=
MIGRATE_JBO_PATH=

# ── 위험 플래그(운영 주의) ──
# 1이면 스위치플랜 하드 wipe 허용 — 평소 비워둘 것.
NEXT_PUBLIC_ALLOW_HARD_WIPE=
