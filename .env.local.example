# jpkerp6 환경변수 템플릿 — 이 파일을 `.env.local` 로 복사하고 값 채운 뒤 dev 재시작하면 실가동.
# (비어 있으면 자동으로 로컬 localStorage 미리보기 모드)

# ── 실행 모드 빠른 가이드 ──
#  A) 로컬 미리보기(로그인 없이 DEV_USERS): Firebase NEXT_PUBLIC_* 전부 비우기
#  B) Firebase 실저장(로그인 필요): Firebase 키 채움 → pyh@teamjpk.com 등 Auth 계정
#  C) 스위치플랜 시드: NEXT_PUBLIC_MIGRATE_MODE=frozen(안전) 또는 auto(live xlsx 시도)
#     live 원천: C:\dev\jpkerp6-마이그레이션\switchplan_스위치플랜\ (사업현황·자금일보 xlsx)
#     반영 UI: /dev/data → 스위치플랜 「반영」

# ── Gemini OCR (고지서·등록증·증권 자동추출) ──
# Google AI Studio(aistudio.google.com) → Get API key
GEMINI_API_KEY=

# ── 마이그레이션 시드 (스위치플랜) ──
# auto | live | frozen | demo  — 기본 auto. 로컬 안정= frozen (lib/migrate/*.json)
NEXT_PUBLIC_MIGRATE_MODE=frozen
# MIGRATE_ROOT=C:\dev\jpkerp6-마이그레이션\switchplan_스위치플랜
# MIGRATE_BIZ_PATH=
# MIGRATE_JBO_PATH=

# ── 문자/알림톡 발송 (Aligo) ──
# 비어 있으면 mock(실발송 X, 발송 흐름·계약 연락기록은 그대로). 키 넣으면 실발송.
#  · ALIGO_SENDER_KEY=카카오 비즈 발신프로필 키(알림톡용, 없으면 SMS만)
#  · ALIGO_FAILOVER='sms'→알림톡 실패 시 SMS 자동대체 / ALIGO_DRY_RUN='true'→발송 흉내(개발)
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER_KEY=
ALIGO_SENDER_TEL=
ALIGO_FAILOVER=
ALIGO_DRY_RUN=

# ── Firebase (Firestore 실저장 + Storage 파일 + Auth) ──
# Firebase 콘솔 → 프로젝트 설정 → 내 앱(웹) → SDK 설정·구성 에서 복사
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (production 인증 — 나중)
# FIREBASE_ADMIN_KEY=

# ── API / 운영 가드 ──
# production에서 /api/* 잠금 — 미설정 시 503. Bearer 토큰과 일치해야 통과.
API_SHARED_SECRET=
# 마스터(부트스트랩) 이메일 — users 문서 없이도 운영자 승격. 비우면 기본 pyh@teamjpk.com
NEXT_PUBLIC_MASTER_EMAIL=
# 프로덕션에서 /dev/data 전체 초기화 허용(=1). 비우면 차단.
NEXT_PUBLIC_ALLOW_HARD_WIPE=

# 참고
#  · NEXT_PUBLIC_FIREBASE_API_KEY 채워지면 getStore()가 Firestore로 자동 전환(로컬→실저장).
#    동시에 세션도 실 로그인으로 전환 → 로그인 화면이 뜹니다(DEV_USERS 자동전환 종료).
#  · 로그인 활성화: Firebase 콘솔 → Authentication → 로그인 방법 → '이메일/비밀번호' 사용.
#  · 마스터(최초 운영자) = NEXT_PUBLIC_MASTER_EMAIL(또는 기본 pyh@teamjpk.com) — users 문서 없이도 운영자로 승격(부트스트랩).
#    이 계정으로 로그인 후 다른 직원 계정에 role·companyId를 배정하세요.
#  · 계정마다 Firestore users/{uid} 문서 필요:
#        { name: '정소유', role: '운영자'|'위탁사', companyId: null|'welrix'|'hanbit' }
#    (운영자=companyId null=전체합본 / 위탁사=자기 회사 고정). 없으면 "계정 미등록" 게이트.
#  · Storage 파일 열람(등록증·증권 원본)은 STORAGE_BUCKET 필요.
#  · GEMINI_API_KEY 없으면 OCR="오류" 배지 → 수기입력으로 진행(플로우 동일).
